        "basedOnGoal",
        "recommendations"
      ]
    },
    "AIPrediction": {
        "title": "AIPrediction",
        "type": "object",
        "description": "A single food prediction generated by the AI model, including confidence score and full nutritional data. This is a superset of the FoodItem entity.",
        "properties": {
            "foodName": {
                "type": "string",
                "description": "The specific name of the identified food. Used as the document ID."
            },
            "confidence": {
                "type": "number",
                "description": "The AI's confidence in this prediction, from 0 to 1."
            },
            "estimatedWeightGrams": {
                "type": "number",
                "description": "The AI's estimated weight in grams for the portion size, typically 100g for search results."
            },
            "calories": {
                "type": "number",
                "description": "Estimated calorie count for the portion specified by estimatedWeightGrams."
            },
            "macronutrientBreakdown": {
                "type": "object",
                "properties": {
                    "protein": { "type": "number", "description": "Grams of protein." },
                    "carbohydrates": { "type": "number", "description": "Grams of carbohydrates." },
                    "fat": { "type": "number", "description": "Grams of fat." }
                },
                "required": ["protein", "carbohydrates", "fat"]
            },
            "micronutrientBreakdown": {
                "type": "object",
                "properties": {
                    "fiber": { "type": "number" }, "sugar": { "type": "number" }, "sodium": { "type": "number" },
                    "calcium": { "type": "number" }, "iron": { "type": "number" }, "potassium": { "type": "number" },
                    "magnesium": { "type": "number" }, "zinc": { "type": "number" }, "phosphorus": { "type": "number" },
                    "iodine": { "type": "number" }, "selenium": { "type": "number" }, "copper": { "type": "number" },
                    "manganese": { "type": "number" }, "chromium": { "type": "number" }, "molybdenum": { "type": "number" },
                    "chloride": { "type": "number" }, "vitaminA": { "type": "number" }, "vitaminC": { "type": "number" },
                    "vitaminD": { "type": "number" }, "vitaminE": { "type": "number" }, "vitaminK": { "type": "number" },
                    "vitaminB1": { "type": "number" }, "vitaminB2": { "type": "number" }, "vitaminB3": { "type": "number" },
                    "vitaminB5": { "type": "number" }, "vitaminB6": { "type": "number" }, "vitaminB7": { "type": "number" },
                    "folate": { "type": "number" }, "vitaminB12": { "type": "number" }
                }
            },
            "detailedRecipe": {
                "type": "object",
                "properties": {
                    "ingredients": { "type": "array", "items": { "type": "string" } },
                    "instructions": { "type": "array", "items": { "type": "string" } }
                }
            },
            "foodHistory": { "type": "string" },
            "healthAnalysis": { "type": "string" },
            "suitability": { "type": "string", "enum": ["Suitable", "Moderately Suitable", "Not Suitable"] },
            "isGhanaianLocal": { "type": "boolean" },
            "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": [
            "foodName",
            "estimatedWeightGrams",
            "calories",
            "macronutrientBreakdown",
            "isGhanaianLocal"
        ]
    },
