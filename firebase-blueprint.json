
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile information, personal details, nutrition goals, and application preferences within the Nutrify application. This data drives personalization and tracking.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity. (Primary Key)"
        },
        "name": {
          "type": "string",
          "description": "User's full name as provided during signup."
        },
        "email": {
          "type": "string",
          "description": "User's email address, used for communication and authentication.",
          "format": "email"
        },
        "onboardingCompleted": {
          "type": "boolean",
          "description": "Flag indicating if the user has completed the initial onboarding wizard."
        },
        "profile": {
          "type": "object",
          "description": "Contains the user's core physical and demographic information.",
          "properties": {
            "gender": {
              "type": "string",
              "description": "User's self-identified gender (e.g., 'Male', 'Female', 'Other')."
            },
            "age": {
              "type": "number",
              "description": "User's age in years."
            },
            "heightCm": {
              "type": "number",
              "description": "User's height in centimeters."
            },
            "weightKg": {
              "type": "number",
              "description": "User's current weight in kilograms."
            },
            "activityLevel": {
              "type": "string",
              "description": "User's self-reported activity level (e.g., 'Low', 'Moderate', 'Active', 'Very Active')."
            },
            "profileImageUrl": {
              "type": "string",
              "description": "URL to the user's profile picture.",
              "format": "uri"
            }
          }
        },
        "health": {
          "type": "object",
          "description": "Contains the user's primary health goals and dietary constraints.",
          "properties": {
            "primaryGoal": {
              "type": "string",
              "description": "User's primary nutrition goal (e.g., 'Lose Weight', 'Maintain Weight', 'Gain Weight', 'Eat Healthier')."
            },
            "dietaryPreferences": {
              "type": "array",
              "description": "An array of dietary restrictions or preferences selected by the user (e.g., 'Vegan', 'Halal', 'Diabetic-Friendly').",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "goals": {
          "type": "object",
          "description": "Contains the user's specific nutritional targets.",
          "properties": {
            "dailyCalorieGoal": {
              "type": "number",
              "description": "The user's target daily calorie intake."
            },
            "proteinPercentageGoal": {
              "type": "number",
              "description": "Target percentage of daily calories from protein (0-100)."
            },
            "carbsPercentageGoal": {
              "type": "number",
              "description": "Target percentage of daily calories from carbohydrates (0-100)."
            },
            "fatPercentageGoal": {
              "type": "number",
              "description": "Target percentage of daily calories from fats (0-100)."
            },
            "ironTargetMg": {
              "type": "number",
              "description": "User's target daily iron intake in milligrams."
            },
            "vitaminATargetMcg": {
              "type": "number",
              "description": "User's target daily Vitamin A intake in micrograms."
            }
          }
        },
        "preferences": {
          "type": "object",
          "description": "Application-specific user preferences.",
          "properties": {
            "unitPreference": {
              "type": "string",
              "description": "Preferred unit system for measurements (e.g., 'metric' for cm/kg, 'imperial' for ft/lbs)."
            },
            "themePreference": {
              "type": "string",
              "description": "User's preferred application theme (e.g., 'Light', 'Dark')."
            },
            "languagePreference": {
              "type": "string",
              "description": "User's preferred language for the application (e.g., 'English', 'Twi', 'Ewe')."
            },
            "reminderEnabled": {
              "type": "boolean",
              "description": "Flag indicating if daily nutrition reminders are enabled for the user."
            },
            "weeklySummaryEnabled": {
              "type": "boolean",
              "description": "Flag indicating if weekly summary notifications are enabled for the user."
            }
          }
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of when the user profile was created.",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "description": "Timestamp of the last update to the user profile.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "name",
        "email",
        "onboardingCompleted",
        "createdAt"
      ]
    },
    "FoodItem": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FoodItem",
      "type": "object",
      "description": "Represents a single food item with its nutritional values, generated by AI. This schema matches the AI output.",
      "properties": {
        "foodName": {
          "type": "string",
          "description": "The specific name of the identified food. Used as the document ID."
        },
        "estimatedWeightGrams": {
          "type": "number",
          "description": "The AI's estimated weight in grams for the portion size, typically 100g for search results."
        },
        "calories": {
          "type": "number",
          "description": "Estimated calorie count for the portion specified by estimatedWeightGrams."
        },
        "macronutrientBreakdown": {
          "type": "object",
          "properties": {
            "protein": {
              "type": "number",
              "description": "Grams of protein."
            },
            "carbohydrates": {
              "type": "number",
              "description": "Grams of carbohydrates."
            },
            "fat": {
              "type": "number",
              "description": "Grams of fat."
            }
          },
          "required": [
            "protein",
            "carbohydrates",
            "fat"
          ]
        },
        "micronutrientBreakdown": {
          "type": "object",
          "properties": {
            "fiber": { "type": "number" },
            "sugar": { "type": "number" },
            "sodium": { "type": "number" },
            "calcium": { "type": "number" },
            "iron": { "type": "number" },
            "potassium": { "type": "number" },
            "magnesium": { "type": "number" },
            "zinc": { "type": "number" },
            "phosphorus": { "type": "number" },
            "iodine": { "type": "number" },
            "selenium": { "type": "number" },
            "copper": { "type": "number" },
            "manganese": { "type": "number" },
            "chromium": { "type": "number" },
            "molybdenum": { "type": "number" },
            "chloride": { "type": "number" },
            "vitaminA": { "type": "number" },
            "vitaminC": { "type": "number" },
            "vitaminD": { "type": "number" },
            "vitaminE": { "type": "number" },
            "vitaminK": { "type": "number" },
            "vitaminB1": { "type": "number" },
            "vitaminB2": { "type": "number" },
            "vitaminB3": { "type": "number" },
            "vitaminB5": { "type": "number" },
            "vitaminB6": { "type": "number" },
            "vitaminB7": { "type": "number" },
            "folate": { "type": "number" },
            "vitaminB12": { "type": "number" }
          }
        },
        "detailedRecipe": {
          "type": "object",
          "properties": {
            "ingredients": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "instructions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "foodHistory": {
          "type": "string"
        },
        "healthAnalysis": {
          "type": "string"
        },
        "suitability": {
          "type": "string",
          "enum": ["Suitable", "Moderately Suitable", "Not Suitable"]
        },
        "isGhanaianLocal": {
          "type": "boolean"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "foodName",
        "estimatedWeightGrams",
        "calories",
        "macronutrientBreakdown",
        "isGhanaianLocal"
      ]
    },
    "LoggedFoodItem": {
      "title": "LoggedFoodItem",
      "type": "object",
      "description": "Represents a single food item logged as part of a meal within a daily log.",
      "properties": {
        "logId": { "type": "string" },
        "foodId": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "fiber": { "type": "number" },
        "sugar": { "type": "number" },
        "sodium": { "type": "number" },
        "calcium": { "type": "number" },
        "iron": { "type": "number" },
        "potassium": { "type": "number" },
        "magnesium": { "type": "number" },
        "zinc": { "type": "number" },
        "phosphorus": { "type": "number" },
        "iodine": { "type": "number" },
        "selenium": { "type": "number" },
        "copper": { "type": "number" },
        "manganese": { "type": "number" },
        "chromium": { "type": "number" },
        "molybdenum": { "type": "number" },
        "chloride": { "type": "number" },
        "vitaminA": { "type": "number" },
        "vitaminC": { "type": "number" },
        "vitaminD": { "type": "number" },
        "vitaminE": { "type": "number" },
        "vitaminK": { "type": "number" },
        "vitaminB1": { "type": "number" },
        "vitaminB2": { "type": "number" },
        "vitaminB3": { "type": "number" },
        "vitaminB5": { "type": "number" },
        "vitaminB6": { "type": "number" },
        "vitaminB7": { "type": "number" },
        "folate": { "type": "number" },
        "vitaminB12": { "type": "number" },
        "imageUrl": { "type": "string", "format": "uri" }
      },
      "required": [
        "logId",
        "foodId",
        "name",
        "quantity",
        "calories"
      ]
    },
    "DailyLog": {
      "title": "DailyLog",
      "type": "object",
      "description": "Aggregated daily nutritional data for a user, including total intake and a list of all food items consumed. Updated with every change in the tracker.",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "totalCalories": { "type": "number" },
        "totalProtein": { "type": "number" },
        "totalCarbs": { "type": "number" },
        "totalFat": { "type": "number" },
        "totalFiber": { "type": "number" },
        "totalSugar": { "type": "number" },
        "totalSodium": { "type": "number" },
        "totalCalcium": { "type": "number" },
        "totalIron": { "type": "number" },
        "totalPotassium": { "type": "number" },
        "totalMagnesium": { "type": "number" },
        "totalZinc": { "type": "number" },
        "totalPhosphorus": { "type": "number" },
        "totalIodine": { "type": "number" },
        "totalSelenium": { "type": "number" },
        "totalCopper": { "type": "number" },
        "totalManganese": { "type": "number" },
        "totalChromium": { "type": "number" },
        "totalMolybdenum": { "type": "number" },
        "totalChloride": { "type": "number" },
        "totalVitaminA": { "type": "number" },
        "totalVitaminC": { "type": "number" },
        "totalVitaminD": { "type": "number" },
        "totalVitaminE": { "type": "number" },
        "totalVitaminK": { "type": "number" },
        "totalVitaminB1": { "type": "number" },
        "totalVitaminB2": { "type": "number" },
        "totalVitaminB3": { "type": "number" },
        "totalVitaminB5": { "type": "number" },
        "totalVitaminB6": { "type": "number" },
        "totalVitaminB7": { "type": "number" },
        "totalFolate": { "type": "number" },
        "totalVitaminB12": { "type": "number" },
        "waterIntake": { "type": "number" },
        "meals": {
          "type": "object",
          "properties": {
            "Breakfast": { "type": "array", "items": { "$ref": "#/backend/entities/LoggedFoodItem" } },
            "Lunch": { "type": "array", "items": { "$ref": "#/backend/entities/LoggedFoodItem" } },
            "Dinner": { "type": "array", "items": { "$ref": "#/backend/entities/LoggedFoodItem" } }
          }
        }
      },
      "required": [
        "date",
        "totalCalories",
        "totalProtein",
        "totalCarbs",
        "totalFat"
      ]
    },
    "PlannedMeal": {
      "title": "PlannedMeal",
      "type": "object",
      "description": "Represents a single food item planned for a specific meal on a specific day.",
      "properties": {
        "foodId": {
          "type": "string",
          "description": "Name of the food, used as an ID since we use AI search."
        },
        "foodName": {
          "type": "string"
        },
        "day": {
          "type": "string",
          "description": "Day of the week, e.g., 'Monday'."
        },
        "mealType": {
          "type": "string",
          "description": "e.g., 'Breakfast', 'Lunch', 'Dinner'."
        },
        "quantity": {
          "type": "number",
          "description": "in grams"
        },
        "calories": {
          "type": "number"
        },
        "protein": {
          "type": "number"
        },
        "carbs": {
          "type": "number"
        },
        "fat": {
          "type": "number"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "foodId",
        "foodName",
        "day",
        "mealType",
        "quantity",
        "calories",
        "protein",
        "carbs",
        "fat",
        "createdAt"
      ]
    },
