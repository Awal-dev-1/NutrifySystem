        "searchedAt",
        "calories",
        "foodData"
      ]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores individual user profile data, preferences, and nutritional goals. The document ID (`{userId}`) matches the Firebase Authentication UID, ensuring path-based ownership and authorization independence.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user, matching their Firebase Authentication UID."
            }
          ]
        }
      },
      {
        "path": "/foodItems/{foodItemId}",
        "definition": {
          "entityName": "FoodItem",
          "schema": {
            "$ref": "#/backend/entities/FoodItem"
          },
          "description": "A global, read-only collection of food items with detailed nutritional information. Accessible by all authenticated users for search and meal logging.",
          "params": [
            {
              "name": "foodItemId",
              "description": "The unique identifier for a specific food item."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/dailyLogs/{date}",
        "definition": {
          "entityName": "DailyLog",
          "schema": {
            "$ref": "#/backend/entities/DailyLog"
          },
          "description": "User-specific collection for storing aggregated daily nutritional data. The document ID is the date in 'YYYY-MM-DD' format. This structure is optimized for fast analytics queries.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the user, derived from the parent collection, matching their Firebase Authentication UID."
            },
            {
              "name": "date",
              "description": "The date of the log in 'YYYY-MM-DD' format."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/generatedRecommendations/{recommendationId}",
        "definition": {
          "entityName": "GeneratedRecommendations",
          "schema": {
            "$ref": "#/backend/entities/GeneratedRecommendations"
          },
          "description": "Stores historical sets of generated meal recommendations for a user. Each document is a snapshot of recommendations at a point in time.",
          "params": [
            {
              "name": "userId",
              "description": "The user's ID."
            },
            {
              "name": "recommendationId",
              "description": "The unique ID for this set of recommendations."
            }
          ]
        }
      },
      {
        "path": "/users/{userId}/aiScans/{scanId}",
        "definition": {
          "entityName": "AIScan",
          "schema": {
            "$ref": "#/backend/entities/AIScan"
          },
